# Anthropic — set ONE of the following.
# Preferred: an API key from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Alternative: an OAuth bearer token (e.g. a Claude Code session token).
# If ANTHROPIC_AUTH_TOKEN is unset, CLAUDE_CODE_OAUTH_TOKEN is also accepted.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Sources (comma-separated)
# RSS sources (BoE, FCA, BBC Your Money)
RSS_FEEDS=https://www.bankofengland.co.uk/rss/news,https://www.fca.org.uk/rss.xml,http://feeds.bbci.co.uk/news/business/your_money/rss.xml,https://www.ft.com/personal-finance?format=rss,https://moneyweek.com/feed/
# GOV.UK search API org slugs (ONS, HMRC) — UK Finance news scraped automatically
GOVUK_ORGS=office-for-national-statistics,hm-revenue-customs
# Generic HTTP listing pages (optional extra sources)
HTTP_SOURCES=
# Minimum relevance score (1-10) to store an article — below this it is dropped
MIN_RELEVANCE_SCORE=6
# Scrape frequency per source — daily | weekly | monthly
SOURCE_SCHEDULES=Bank of England=weekly,Financial Conduct Authority (FCA)=weekly,BBC Your Money=daily,Office For National Statistics=monthly,Hm Revenue Customs=monthly,Financial Times=weekly,MoneyWeek=weekly

# Storage
DB_PATH=./data/articles.db
OUTPUT_DIR=./output

# Output toggles (true/false)
ENABLE_LOCAL=true
ENABLE_GMAIL=false
ENABLE_NOTION=false

# Gmail SMTP (use an app password, not your account password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TO=

# Notion integration
NOTION_TOKEN=
NOTION_DATABASE_ID=

# OG / social image — URL to a default Warren brand image stamped into every
# blog post's markdown frontmatter (og_image + image fields). Leave blank to
# omit. Example: https://meetwarren.co.uk/images/og-default.jpg
WARREN_OG_IMAGE=
